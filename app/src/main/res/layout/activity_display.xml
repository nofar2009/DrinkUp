<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#F0F8FF">

    <TextView
        android:id="@+id/tvTitleDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Water Tracking"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#80CBC4"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/etWaterDrank"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="how many cups did you drunk today?"
        android:inputType="number"
        android:minHeight="48dp"
        android:padding="10dp"
        android:importantForAutofill="no" />

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="send"
        android:layout_marginTop="16dp"
        android:backgroundTint="#80CBC4"
        android:textColor="#FFFFFF" />

    <LinearLayout
        android:id="@+id/dynamicContainer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="vertical" />

</LinearLayout>